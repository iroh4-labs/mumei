# Dashboard subproject — Node/Vite artifacts.
# Repo root .gitignore covers .mumei/, /docs, /CLAUDE.md, etc; this
# file scopes additional ignores to dashboard/-relative paths.

node_modules/
dist/
dist-ssr/
*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Type-check incremental info
*.tsbuildinfo

# Stray .mumei/ created if dashboard ever runs from this dir before
# the walk-up resolver kicks in (defence in depth).
.mumei/
