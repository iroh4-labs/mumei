{
  "name": "@mumei/dashboard",
  "version": "0.1.0",
  "description": "Local dev dashboard for mumei: realtime visualisation of feature phases, Wave progress, review verdicts, token cost, and hook firing trends. Reads .mumei/ directly, no external service.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hir4ta/mumei.git",
    "directory": "dashboard"
  },
  "homepage": "https://github.com/hir4ta/mumei/tree/main/dashboard#readme",
  "bugs": "https://github.com/hir4ta/mumei/issues",
  "bin": {
    "mumei-dashboard": "./bin/mumei-dashboard.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names \"server,vite\" --prefix-colors \"magenta,cyan\" \"npm:dev:server\" \"npm:dev:vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "generate-types": "tsx scripts/generate-types.ts",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^5.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "json-schema-to-typescript": "^15.0.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
