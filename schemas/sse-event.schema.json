{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/sse-event.schema.json",
  "title": "mumei dashboard SSE event",
  "description": "Server-Sent Events emitted by dashboard/server/sse.ts on /api/events. All events are debounced 200ms per (event, slug). state.json updates emit BOTH feature.update AND activity.changed; review/hook activity emits only activity.changed. The client treats activity.changed and activity.added as cache-invalidation triggers and refetches /api/activity. Producer: backend chokidar -> EventEmitter pipeline. Consumer: dashboard/src/hooks/useEventStream.ts.",
  "anyOf": [
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "feature.update",
          "type": "string"
        },
        "slug": {
          "pattern": "^(REQ-[0-9]+(-[a-z0-9-]+)?|[a-z0-9][a-z0-9-]*)$",
          "description": "Feature key whose state.json or review changed (REQ-N-slug for spec, bare slug for plan); useEventStream invalidates ['features'], ['feature', slug, 'detail'], AND ['meta','stats']. Omit when the change is project-wide (e.g. .hook-stats.jsonl) and only `affects` is meaningful.",
          "type": "string"
        },
        "affects": {
          "uniqueItems": true,
          "description": "Trend kinds whose underlying data changed. useEventStream invalidates `['trend', kind, ...]` for each entry, in addition to the slug-scoped invalidations above. Omit when no trend is affected.",
          "type": "array",
          "items": {
            "anyOf": [
              {
                "const": "hooks",
                "type": "string"
              },
              {
                "const": "reviews",
                "type": "string"
              },
              {
                "const": "tokens",
                "type": "string"
              }
            ]
          }
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "cost.updated",
          "type": "string"
        },
        "slug": {
          "description": "Feature slug owning the cost-log, or null when the change was project-wide.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "activity.changed",
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "event"
      ],
      "properties": {
        "type": {
          "const": "activity.added",
          "type": "string"
        },
        "event": {
          "anyOf": [
            {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "ts",
                "kind",
                "ref",
                "message"
              ],
              "properties": {
                "ts": {
                  "format": "date-time",
                  "type": "string"
                },
                "kind": {
                  "const": "commit",
                  "type": "string"
                },
                "slug": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "ref": {
                  "pattern": "^[0-9a-f]{7,40}$",
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            },
            {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "ts",
                "kind",
                "slug",
                "verdict",
                "iter"
              ],
              "properties": {
                "ts": {
                  "format": "date-time",
                  "type": "string"
                },
                "kind": {
                  "const": "review",
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                },
                "verdict": {
                  "anyOf": [
                    {
                      "const": "PASS",
                      "type": "string"
                    },
                    {
                      "const": "NEEDS_IMPROVEMENT",
                      "type": "string"
                    },
                    {
                      "const": "MAJOR_ISSUES",
                      "type": "string"
                    }
                  ]
                },
                "iter": {
                  "minimum": 1,
                  "maximum": 3,
                  "type": "integer"
                }
              }
            },
            {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "ts",
                "kind",
                "slug",
                "from",
                "to"
              ],
              "properties": {
                "ts": {
                  "format": "date-time",
                  "type": "string"
                },
                "kind": {
                  "const": "phase",
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                },
                "from": {
                  "anyOf": [
                    {
                      "const": "plan",
                      "type": "string"
                    },
                    {
                      "const": "implement",
                      "type": "string"
                    },
                    {
                      "const": "review",
                      "type": "string"
                    },
                    {
                      "const": "done",
                      "type": "string"
                    }
                  ]
                },
                "to": {
                  "anyOf": [
                    {
                      "const": "plan",
                      "type": "string"
                    },
                    {
                      "const": "implement",
                      "type": "string"
                    },
                    {
                      "const": "review",
                      "type": "string"
                    },
                    {
                      "const": "done",
                      "type": "string"
                    }
                  ]
                }
              }
            },
            {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "ts",
                "kind",
                "hook_id",
                "decision"
              ],
              "properties": {
                "ts": {
                  "format": "date-time",
                  "type": "string"
                },
                "kind": {
                  "const": "hook",
                  "type": "string"
                },
                "hook_id": {
                  "description": "Hook rule short id emitted by hooks/_lib/hook-stats.sh:mumei_hook_stats_record.",
                  "type": "string"
                },
                "decision": {
                  "anyOf": [
                    {
                      "const": "allow",
                      "type": "string"
                    },
                    {
                      "const": "deny",
                      "type": "string"
                    },
                    {
                      "const": "warn",
                      "type": "string"
                    },
                    {
                      "const": "block",
                      "type": "string"
                    },
                    {
                      "const": "noop",
                      "type": "string"
                    },
                    {
                      "const": "pass",
                      "type": "string"
                    },
                    {
                      "const": "error",
                      "type": "string"
                    }
                  ]
                }
              }
            }
          ]
        }
      }
    }
  ]
}
