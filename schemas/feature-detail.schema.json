{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/feature-detail.schema.json#v0.1.0",
  "title": "mumei feature detail payload",
  "description": "GET /api/feature/:slug/detail result built by dashboard/server/detail.ts from requirements.md + tasks.md (via execFile bash hooks/_lib/tasks.sh) + reviews/*.json + cost-log.jsonl. When planVehicle=true, requirements.md is absent so acs is []. Producer: dashboard backend. Consumer: DetailPanel.tsx.",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "slug",
    "planVehicle",
    "timeline",
    "acs",
    "waveplan",
    "reviews",
    "costPerIter"
  ],
  "properties": {
    "slug": {
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "type": "string"
    },
    "planVehicle": {
      "description": "True when feature lives under .mumei/plans/<slug>/ (no requirements.md). Frontend renders 'no requirements (plan vehicle)' placeholder for the ACs tab.",
      "type": "boolean"
    },
    "archived": {
      "description": "True when the feature was found under .mumei/archive/<YYYY-MM>/<slug>/ instead of active specs/plans. Frontend may surface an 'archived' badge to signal that further realtime updates will not arrive (REQ-18.15).",
      "type": "boolean"
    },
    "timeline": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "ts",
          "event"
        ],
        "properties": {
          "ts": {
            "format": "date-time",
            "type": "string"
          },
          "event": {
            "description": "Short label, e.g. 'created', 'phase: plan -> implement', 'wave 2 commit', 'review iter 1 PASS'.",
            "type": "string"
          },
          "ref": {
            "description": "git rev / review JSON path / null.",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "acs": {
      "description": "Empty array when planVehicle=true.",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "body",
          "confirmed"
        ],
        "properties": {
          "id": {
            "pattern": "^REQ-[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "confirmed": {
            "description": "True for [CONFIRMED] ACs, false for [ASSUMPTION] / [NEEDS CLARIFICATION].",
            "type": "boolean"
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "waveplan": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "wave",
          "goal",
          "verify",
          "tasks"
        ],
        "properties": {
          "wave": {
            "minimum": 1,
            "type": "integer"
          },
          "goal": {
            "type": "string"
          },
          "verify": {
            "type": "string"
          },
          "tasks": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "id",
                "description",
                "done",
                "files",
                "depends",
                "reqs"
              ],
              "properties": {
                "id": {
                  "pattern": "^[0-9]+\\.[0-9]+$",
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "done": {
                  "type": "boolean"
                },
                "files": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "depends": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "reqs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "ts",
          "verdict",
          "iteration"
        ],
        "properties": {
          "ts": {
            "format": "date-time",
            "type": "string"
          },
          "verdict": {
            "anyOf": [
              {
                "const": "PASS",
                "type": "string"
              },
              {
                "const": "NEEDS_IMPROVEMENT",
                "type": "string"
              },
              {
                "const": "MAJOR_ISSUES",
                "type": "string"
              }
            ]
          },
          "iteration": {
            "minimum": 1,
            "maximum": 3,
            "type": "integer"
          },
          "wave": {
            "anyOf": [
              {
                "minimum": 1,
                "type": "integer"
              },
              {
                "const": "all",
                "type": "string"
              }
            ]
          },
          "findings": {
            "type": "array",
            "items": {
              "additionalProperties": true,
              "type": "object",
              "required": [
                "severity",
                "message"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "severity": {
                  "anyOf": [
                    {
                      "const": "LOW",
                      "type": "string"
                    },
                    {
                      "const": "MEDIUM",
                      "type": "string"
                    },
                    {
                      "const": "HIGH",
                      "type": "string"
                    },
                    {
                      "const": "CRITICAL",
                      "type": "string"
                    }
                  ]
                },
                "category": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "costPerIter": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "iter",
          "tokens",
          "cacheHit"
        ],
        "properties": {
          "iter": {
            "minimum": 1,
            "maximum": 3,
            "type": "integer"
          },
          "tokens": {
            "minimum": 0,
            "type": "integer"
          },
          "cacheHit": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          }
        }
      }
    }
  }
}
