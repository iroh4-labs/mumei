{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/activity-event.schema.json",
  "title": "mumei activity event",
  "description": "Discriminated union of activity entries returned by GET /api/activity?limit=50 and prepended into ActivityFeed via SSE 'activity.added'. Producer: dashboard/server/activity.ts (merging git log + reviews/*.json + state.json mtime + .hook-stats.jsonl, active + archive). Consumer: dashboard/src/components/ActivityFeed.tsx.",
  "anyOf": [
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "ref",
        "message"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "commit",
          "type": "string"
        },
        "slug": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "ref": {
          "pattern": "^[0-9a-f]{7,40}$",
          "description": "git short or full SHA.",
          "type": "string"
        },
        "message": {
          "description": "First line of commit message.",
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "slug",
        "verdict",
        "iter"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "review",
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "verdict": {
          "anyOf": [
            {
              "const": "PASS",
              "type": "string"
            },
            {
              "const": "NEEDS_IMPROVEMENT",
              "type": "string"
            },
            {
              "const": "MAJOR_ISSUES",
              "type": "string"
            }
          ]
        },
        "iter": {
          "minimum": 1,
          "maximum": 3,
          "type": "integer"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "slug",
        "from",
        "to"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "phase",
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "from": {
          "description": "Previous phase. null when transition history is unavailable (no audit-log entry); UI renders as '→ <to>' in that case.",
          "anyOf": [
            {
              "anyOf": [
                {
                  "const": "plan",
                  "type": "string"
                },
                {
                  "const": "implement",
                  "type": "string"
                },
                {
                  "const": "review",
                  "type": "string"
                },
                {
                  "const": "done",
                  "type": "string"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "to": {
          "anyOf": [
            {
              "const": "plan",
              "type": "string"
            },
            {
              "const": "implement",
              "type": "string"
            },
            {
              "const": "review",
              "type": "string"
            },
            {
              "const": "done",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "hook_id",
        "decision"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "hook",
          "type": "string"
        },
        "hook_id": {
          "description": "Hook rule short id emitted by hooks/_lib/hook-stats.sh:mumei_hook_stats_record.",
          "type": "string"
        },
        "decision": {
          "anyOf": [
            {
              "const": "allow",
              "type": "string"
            },
            {
              "const": "deny",
              "type": "string"
            },
            {
              "const": "warn",
              "type": "string"
            },
            {
              "const": "block",
              "type": "string"
            },
            {
              "const": "noop",
              "type": "string"
            },
            {
              "const": "pass",
              "type": "string"
            },
            {
              "const": "error",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "slug",
        "agent",
        "phase",
        "tokens_total"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "subagent",
          "type": "string"
        },
        "slug": {
          "description": "Owning feature key (REQ-N-slug for spec, bare slug for plan).",
          "type": "string"
        },
        "agent": {
          "description": "Subagent name (e.g. spec-compliance-reviewer).",
          "type": "string"
        },
        "phase": {
          "description": "Cost-log phase marker; before / after for delta computation.",
          "anyOf": [
            {
              "const": "before",
              "type": "string"
            },
            {
              "const": "after",
              "type": "string"
            }
          ]
        },
        "tokens_total": {
          "minimum": 0,
          "description": "input_tokens + output_tokens at this entry.",
          "type": "integer"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "slug",
        "vehicle",
        "task_id"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "task_progress",
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "vehicle": {
          "anyOf": [
            {
              "const": "spec",
              "type": "string"
            },
            {
              "const": "plan",
              "type": "string"
            }
          ]
        },
        "wave": {
          "description": "Wave number for spec vehicle; null for plan vehicle.",
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "task_id": {
          "description": "Spec: <wave>.<task> like '1.2'. Plan: post-increment task counter as a string.",
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ts",
        "kind",
        "slug",
        "to"
      ],
      "properties": {
        "ts": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "const": "archive",
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "to": {
          "description": "Archive destination path (.mumei/archive/<YYYY-MM>/<slug>).",
          "type": "string"
        }
      }
    }
  ]
}
