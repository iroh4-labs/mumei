{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/review.schema.json",
  "title": "mumei review pipeline output",
  "description": "Phase 5 / /mumei:review pipeline verdict, persisted at .mumei/specs/<feature>/reviews/<ts>.json (spec vehicle) or .mumei/plans/<slug>/reviews/<ts>.json (plan vehicle).",
  "type": "object",
  "required": [
    "iteration",
    "verdict"
  ],
  "properties": {
    "feature": {
      "description": "REQ-N-slug or plan-vehicle bare slug.",
      "type": "string"
    },
    "wave": {
      "description": "Wave under review, or 'all' for end-of-feature pipelines.",
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "const": "all",
          "type": "string"
        }
      ]
    },
    "iteration": {
      "minimum": 1,
      "description": "Review iter index. Current orchestrator caps at 3 (REQ-7.6 short-circuit) but historical reviews under archive may carry higher values from earlier iter caps.",
      "type": "integer"
    },
    "iter_head": {
      "pattern": "^[0-9a-f]{7,40}$",
      "description": "git rev-parse HEAD at iter completion. Used by Stage 0 detector skip logic in iter N+1.",
      "type": "string"
    },
    "verdict": {
      "anyOf": [
        {
          "const": "PASS",
          "type": "string"
        },
        {
          "const": "NEEDS_IMPROVEMENT",
          "type": "string"
        },
        {
          "const": "MAJOR_ISSUES",
          "type": "string"
        }
      ]
    },
    "summary": {
      "description": "Human-readable summary of the review verdict. Older archived reviews may omit this field.",
      "type": "string"
    },
    "reviewers": {
      "description": "Per-reviewer verdict map. Keys are reviewer short names (spec-compliance / security / adversarial).",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "verdict": {
                  "type": "string"
                }
              }
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "findings_surfaced": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "reviewer": {
            "type": "string"
          },
          "severity": {
            "anyOf": [
              {
                "const": "LOW",
                "type": "string"
              },
              {
                "const": "MEDIUM",
                "type": "string"
              },
              {
                "const": "HIGH",
                "type": "string"
              },
              {
                "const": "CRITICAL",
                "type": "string"
              }
            ]
          },
          "category": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "source": {
            "description": "Detector ground-truth marker: 'semgrep' / 'osv-scanner' / 'structural-integrity' for deterministic findings.",
            "type": "string"
          },
          "validator": {
            "type": "object",
            "properties": {
              "decision": {
                "anyOf": [
                  {
                    "const": "valid",
                    "type": "string"
                  },
                  {
                    "const": "invalid",
                    "type": "string"
                  },
                  {
                    "const": "unsure",
                    "type": "string"
                  },
                  {
                    "const": "valid_by_assertion",
                    "type": "string"
                  }
                ]
              },
              "confidence": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "findings_filtered": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "reviewer": {
            "type": "string"
          },
          "severity": {
            "anyOf": [
              {
                "const": "LOW",
                "type": "string"
              },
              {
                "const": "MEDIUM",
                "type": "string"
              },
              {
                "const": "HIGH",
                "type": "string"
              },
              {
                "const": "CRITICAL",
                "type": "string"
              }
            ]
          },
          "category": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "source": {
            "description": "Detector ground-truth marker: 'semgrep' / 'osv-scanner' / 'structural-integrity' for deterministic findings.",
            "type": "string"
          },
          "validator": {
            "type": "object",
            "properties": {
              "decision": {
                "anyOf": [
                  {
                    "const": "valid",
                    "type": "string"
                  },
                  {
                    "const": "invalid",
                    "type": "string"
                  },
                  {
                    "const": "unsure",
                    "type": "string"
                  },
                  {
                    "const": "valid_by_assertion",
                    "type": "string"
                  }
                ]
              },
              "confidence": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "next_iter_reviewers": {
      "description": "Reviewer set to launch in iter N+1. Always contains 'adversarial' (REQ-7.3 invariant).",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "detector_skipped": {
      "description": "REQ-7.5: true when iter 2+ skipped Stage 0 because no detector-relevant file changed since iter N-1.",
      "type": "boolean"
    },
    "detector_reused_from": {
      "description": "Path to the previous iter's detector report when detector_skipped == true.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "detector_report": {
      "description": "Path to <ts>-detectors.json with raw semgrep / osv-scanner findings.",
      "type": "string"
    },
    "short_circuited_from": {
      "description": "Path to the prior review JSON when this entry is a REQ-7.7 short-circuit synthetic record.",
      "type": "string"
    }
  }
}
