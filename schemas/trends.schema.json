{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "$id": "https://mumei.dev/schemas/tokens-trend.schema.json#v0.1.0",
      "title": "mumei tokens trend",
      "description": "GET /api/trends/tokens?days=14 result. Daily total of input + output tokens from cost-log.jsonl. Days with no entries are emitted as v=0.",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "d",
          "v"
        ],
        "properties": {
          "d": {
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "ISO calendar day (UTC), zero-padded.",
            "type": "string"
          },
          "v": {
            "minimum": 0,
            "type": "integer"
          }
        }
      }
    },
    {
      "$id": "https://mumei.dev/schemas/reviews-trend.schema.json#v0.1.0",
      "title": "mumei reviews trend",
      "description": "GET /api/trends/reviews?days=14 result. Daily count of review JSON files grouped by verdict.",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "d",
          "PASS",
          "NI",
          "MI"
        ],
        "properties": {
          "d": {
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "ISO calendar day (UTC), zero-padded.",
            "type": "string"
          },
          "PASS": {
            "minimum": 0,
            "type": "integer"
          },
          "NI": {
            "minimum": 0,
            "description": "NEEDS_IMPROVEMENT count.",
            "type": "integer"
          },
          "MI": {
            "minimum": 0,
            "description": "MAJOR_ISSUES count.",
            "type": "integer"
          }
        }
      }
    },
    {
      "$id": "https://mumei.dev/schemas/hooks-trend.schema.json#v0.1.0",
      "title": "mumei hooks trend",
      "description": "GET /api/trends/hooks?topN=10&windowH=24 result. Top-N hook_id rows by firing count within the window.",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "hook_id",
          "count",
          "decision"
        ],
        "properties": {
          "hook_id": {
            "description": "Hook rule short id emitted by hooks/_lib/hook-stats.sh:mumei_hook_stats_record (e.g. S1, M1, X3, I1).",
            "type": "string"
          },
          "count": {
            "minimum": 1,
            "type": "integer"
          },
          "decision": {
            "description": "Most common decision recorded for the hook_id within the window.",
            "anyOf": [
              {
                "const": "allow",
                "type": "string"
              },
              {
                "const": "deny",
                "type": "string"
              },
              {
                "const": "warn",
                "type": "string"
              },
              {
                "const": "block",
                "type": "string"
              },
              {
                "const": "noop",
                "type": "string"
              }
            ]
          }
        }
      }
    }
  ]
}
